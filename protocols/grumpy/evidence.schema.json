{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Grumpy review evidence",
  "type": "object",
  "required": ["files"],
  "properties": {
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "verdicts"],
        "properties": {
          "path": { "type": "string" },
          "verdicts": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["category", "verdict"],
              "properties": {
                "category": { "enum": ["naming", "error-handling", "performance", "duplication", "security"] },
                "verdict": { "enum": ["issues-found", "none-found"] },
                "findings": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["existing_code", "comment"],
                    "properties": {
                      "existing_code": { "type": "string", "minLength": 1 },
                      "comment": { "type": "string", "minLength": 1 }
                    }
                  }
                },
                "examined": { "type": "array", "items": { "type": "string", "minLength": 1 } }
              },
              "allOf": [
                { "if": { "properties": { "verdict": { "const": "issues-found" } } },
                  "then": { "required": ["findings"], "properties": { "findings": { "minItems": 1 } } } },
                { "if": { "properties": { "verdict": { "const": "none-found" } } },
                  "then": { "required": ["examined"], "properties": { "examined": { "minItems": 1 } } } }
              ]
            }
          }
        }
      }
    }
  }
}
