{
  "name": "cap-mp-fanout-gate",
  "version": "0.1.0",
  "triggers": [
    { "on": "issue_comment", "comment_prefix": "/cap-run", "command": "start" },
    { "on": "issue_comment", "comment_prefix": "/answer", "command": "answer" }
  ],
  "states": [
    {
      "id": "preflight",
      "kind": "agent",
      "workflow": "preflight-agent",
      "max_iterations": 2,
      "checks": [{ "run": "always-pass", "on_fail": "iterate" }],
      "next": "review"
    },
    {
      "id": "review",
      "kind": "fanout",
      "branches": [
        {
          "id": "B",
          "states": [
            {
              "id": "draft",
              "kind": "agent",
              "workflow": "draft-agent",
              "max_iterations": 2,
              "checks": [{ "run": "always-pass", "on_fail": "iterate" }]
            },
            {
              "id": "clarify",
              "kind": "gate",
              "questions_from": "draft",
              "checks": [{ "run": "answers-coverage", "on_fail": "iterate" }]
            },
            {
              "id": "finalize",
              "kind": "agent",
              "workflow": "finalize-agent",
              "max_iterations": 2,
              "checks": [{ "run": "always-pass", "on_fail": "iterate" }]
            }
          ]
        }
      ],
      "next": "join"
    },
    { "id": "join", "kind": "join", "of": "review", "next": "done" }
  ]
}
