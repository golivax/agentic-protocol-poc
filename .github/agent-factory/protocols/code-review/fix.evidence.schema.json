{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "fix suggestions evidence",
  "type": "object",
  "required": ["fixes", "mode"],
  "properties": {
    "fixes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["cluster_id", "path", "line", "rationale", "suggested_patch"],
        "properties": {
          "cluster_id": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "minLength": 1 },
          "line": { "type": "integer", "minimum": 1 },
          "rationale": { "type": "string", "minLength": 1 },
          "suggested_patch": { "type": "string", "minLength": 1 }
        }
      }
    },
    "skipped": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["cluster_id", "reason"],
        "properties": {
          "cluster_id": { "type": "string", "minLength": 1 },
          "reason": { "type": "string", "minLength": 1 }
        }
      }
    },
    "mode": { "type": "string", "enum": ["suggest"] }
  }
}
