{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["cluster", "legs"],
  "properties": {
    "cluster": {"type": "string", "minLength": 1, "description": "the cluster id (e.g. adherence or consistency)"},
    "legs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["leg", "scope", "gather_verdict", "graded_findings"],
        "properties": {
          "leg": {"type": "string", "minLength": 1},
          "scope": {"type": "object", "description": "echoed verbatim from the inner judge's scope ({} for legs with no scope)"},
          "gather_verdict": {"type": "string", "minLength": 1, "description": "echoed verbatim from the inner judge's gather_verdict"},
          "graded_findings": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["ref", "severity", "rationale"],
              "properties": {
                "ref": {"type": "string", "minLength": 1},
                "severity": {"enum": ["blocking", "advisory", "noise"]},
                "rationale": {"type": "string"}
              }
            }
          }
        }
      }
    }
  }
}
