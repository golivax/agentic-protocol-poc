{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "mrp merge-readiness pack (synthesis) evidence",
  "type": "object",
  "required": ["rationale", "critique_ledger", "routed_questions", "acceptance", "acceptance_plan"],
  "properties": {
    "rationale": {
      "type": ["object", "null"],
      "properties": {
        "summary": { "type": "string" },
        "keyPoints": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["point", "snippet", "source"],
            "properties": {
              "point": { "type": "string" },
              "snippet": { "type": "string" },
              "source": { "type": "string", "enum": ["conversation", "walkthrough"] }
            }
          }
        },
        "intentMatch": { "type": "string", "enum": ["aligned", "partial", "unclear"] }
      }
    },
    "critique_ledger": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["dimension", "severity", "title"],
        "properties": {
          "dimension": { "type": "string" },
          "path": { "type": ["string", "null"] },
          "line": { "type": ["integer", "null"] },
          "severity": { "type": "string" },
          "verdict": { "type": "string" },
          "title": { "type": "string" },
          "rationale": { "type": "string" }
        }
      }
    },
    "routed_questions": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "acceptance": {
      "type": "object",
      "required": ["recommendation", "reasons"],
      "properties": {
        "recommendation": { "type": "string", "enum": ["accept", "hold"] },
        "reasons": { "type": "array", "items": { "type": "string" } }
      }
    },
    "acceptance_plan": {
      "type": "object",
      "required": ["per_cohort", "staged_rungs"],
      "properties": {
        "per_cohort": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["cohort", "band", "rung"],
            "properties": {
              "cohort": { "type": ["string", "null"] },
              "band": { "type": "string", "enum": ["Low", "Medium", "High", "Critical"] },
              "rung": { "type": "string" },
              "routed_question": { "type": "string" },
              "spot_ids": { "type": "array" },
              "l4_pending": { "type": "boolean" }
            }
          }
        },
        "staged_rungs": { "type": "array", "items": { "type": "string" } }
      }
    },
    "riskBand": { "type": ["string", "null"] },
    "meta": {
      "type": "object",
      "properties": {
        "pr_number": { "type": ["integer", "null"] },
        "head_sha": { "type": "string" }
      }
    },
    "pack": {
      "type": "object",
      "required": ["path", "error"],
      "properties": {
        "path": { "type": "string" },
        "error": { "type": "boolean" }
      }
    }
  }
}
