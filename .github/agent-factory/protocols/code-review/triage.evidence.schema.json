{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "review triage evidence",
  "type": "object",
  "required": ["clusters", "summary"],
  "properties": {
    "clusters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["cluster_id", "title", "dimension", "severity", "paths", "member_findings", "rank"],
        "properties": {
          "cluster_id": { "type": "string" },
          "title": { "type": "string" },
          "dimension": {
            "type": "array",
            "items": { "type": "string", "enum": ["correctness", "test", "performance", "security", "maintainability"] }
          },
          "severity": { "type": "string", "enum": ["critical", "high", "medium", "low"] },
          "paths": { "type": "array", "items": { "type": "string" } },
          "member_findings": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["dimension", "path", "severity", "title"],
              "properties": {
                "dimension": { "type": "string", "enum": ["correctness", "test", "performance", "security", "maintainability"] },
                "path": { "type": "string" },
                "line": { "type": ["integer", "null"] },
                "severity": { "type": "string", "enum": ["critical", "high", "medium", "low"] },
                "category": { "type": "string" },
                "title": { "type": "string" },
                "impact": { "type": "string" },
                "fix": { "type": "string" }
              }
            }
          },
          "rank": { "type": "integer", "minimum": 1 }
        }
      }
    },
    "summary": {
      "type": "object",
      "required": ["present", "missing", "clusters", "total_findings", "by_severity", "by_dimension"],
      "properties": {
        "present": { "type": "array", "items": { "type": "string" } },
        "missing": { "type": "array", "items": { "type": "string" } },
        "clusters": { "type": "integer", "minimum": 0 },
        "total_findings": { "type": "integer", "minimum": 0 },
        "by_severity": { "type": "object" },
        "by_dimension": { "type": "object" }
      }
    }
  }
}
