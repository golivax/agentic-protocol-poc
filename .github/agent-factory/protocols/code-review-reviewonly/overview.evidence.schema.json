{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "guided overview + risk evidence",
  "type": "object",
  "required": ["cohorts", "summary", "risk_band"],
  "properties": {
    "cohorts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["cohort", "cohortOrder", "area", "files", "layers", "bcFindings"],
        "properties": {
          "cohort": { "type": "string" },
          "cohortOrder": { "type": "integer", "minimum": 1 },
          "area": { "type": "string", "enum": ["security", "frontend", "backend", "data", "infra", "docs", "tests"] },
          "files": { "type": "array", "items": { "type": "string" } },
          "layers": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["layer", "order", "area", "title", "summary", "files", "diff"],
              "properties": {
                "layer": { "type": "string", "enum": ["schema", "backend", "api", "frontend", "tests", "other"] },
                "order": { "type": "integer", "minimum": 1 },
                "area": { "type": "string", "enum": ["security", "frontend", "backend", "data", "infra", "docs", "tests"] },
                "title": { "type": "string" },
                "summary": { "type": "string" },
                "files": { "type": "array", "items": { "type": "string" } },
                "diff": { "type": "string" },
                "diagram": { "type": "string" }
              }
            }
          },
          "bcFindings": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["symbol", "kind", "category", "severityClass", "evidence"],
              "properties": {
                "symbol": { "type": "string" },
                "kind": { "type": "string", "enum": ["type", "method", "field"] },
                "category": { "type": "string" },
                "severityClass": { "type": "string", "enum": ["hard-break", "recoverable-refactor"] },
                "evidence": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "summary": { "type": "string" },
    "risk_band": { "type": "string", "enum": ["Low", "Medium", "High", "Critical"] }
  }
}