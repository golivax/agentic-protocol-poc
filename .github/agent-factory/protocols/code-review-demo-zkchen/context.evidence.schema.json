{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "context 7-phase classification evidence",
  "type": "object",
  "required": ["phases", "transcript_present", "meta", "session_export"],
  "properties": {
    "transcript_present": { "type": "boolean" },
    "phases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["phase", "token_count", "message_count"],
        "properties": {
          "phase": {
            "type": "string",
            "enum": ["UNDERSTAND", "EXPLORE", "ANALYZE", "PLAN", "IMPLEMENT", "VERIFY", "COMPLETE"]
          },
          "message_count": { "type": "integer", "minimum": 0 },
          "token_count": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "meta": {
      "type": "object",
      "properties": {
        "pr_number": { "type": "integer" },
        "head_sha": { "type": "string" }
      }
    },
    "session_export": {
      "type": "object",
      "required": ["path", "error"],
      "properties": {
        "path": { "type": "string" },
        "error": { "type": "boolean" },
        "summary": { "type": "string" }
      }
    },
    "summary": { "type": "string" }
  }
}
