{
  "name": "grumpy-review",
  "version": "0.1.0",
  "triggers": [
    { "on": "issue_comment", "comment_prefix": "/grumpy", "command": "start" },
    { "on": "pull_request",  "actions": ["opened", "reopened"], "command": "start" },
    { "on": "pull_request",  "actions": ["synchronize"], "command": "reset" }
  ],
  "states": [
    {
      "id": "review",
      "kind": "agent",
      "workflow": "grumpy-agent",
      "evidence": "evidence.schema.json",
      "max_iterations": 3,
      "params": { "categories": ["naming", "error-handling", "performance", "duplication", "security"] },
      "checks": [
        { "run": "schema-valid", "on_fail": "iterate" },
        { "run": "rubric-coverage", "on_fail": "iterate" },
        { "run": "traces-exist-in-diff", "on_fail": "iterate" }
      ],
      "next": "publish"
    },
    {
      "id": "publish",
      "kind": "deterministic",
      "action": "publish-review-from-evidence",
      "next": null
    }
  ]
}
